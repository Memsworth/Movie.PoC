@page
@model Movie.PoC.WebApp.Pages.Film.AddModel
@{
    ViewData["Title"] = "Add Film";
}

<form method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label asp-for="Film.Title"></label>
        <input asp-for="Film.Title" class="form-control" />
        <span asp-validation-for="Film.Title" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>ImageUrl</label>
        <input type="file" asp-for="ImageFile" class="form-control" />
        <span asp-validation-for="ImageFile" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Film.ReleaseDate"></label>
        <input asp-for="Film.ReleaseDate" type="date" class="form-control" />
        <span asp-validation-for="Film.ReleaseDate" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Film.Genre"></label>
        <input asp-for="Film.Genre" class="form-control" />
        <span asp-validation-for="Film.Genre" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Add Film</button>
</form>