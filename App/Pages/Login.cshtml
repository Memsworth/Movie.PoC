@page
@model App.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="container">
    <form method="post">
        <div class="form-group">
            <label asp-for="Registration.Email"></label>
            <input asp-for="Registration.Email" class="form-control form-control-sm" />
            <span asp-validation-for="Registration.Email" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Registration.Password"></label>
            <input asp-for="Registration.Password" type="password" class="form-control form-control-sm" />
            <span asp-validation-for="Registration.Password" class="text-danger"></span>
        </div>
    </form>
</div>